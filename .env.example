# ── Backend ──────────────────────────────────────────────────────────────────
PORT=3000
DATABASE_URL=postgresql://busadmin:CHANGE_ME@postgres:5432/busbarranquilla
JWT_SECRET=CHANGE_ME_use_a_long_random_string
REDIS_URL=redis://redis:6379
WOMPI_PUBLIC_KEY=pub_test_xxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxx
WOMPI_EVENT_SECRET=test_events_xxxxx
APP_URL=http://localhost:5173

# ── PostgreSQL (solo para docker-compose local) ───────────────────────────────
POSTGRES_USER=busadmin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=busbarranquilla

# ── Web (build-time) ──────────────────────────────────────────────────────────
# URL del backend en producción (Railway). Sin barra al final.
# En Vercel: configúralos como variables de entorno en el dashboard.
VITE_API_URL=https://api.mibus.co
VITE_GOOGLE_MAPS_KEY=CHANGE_ME
